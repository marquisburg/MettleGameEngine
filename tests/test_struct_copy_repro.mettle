// Minimal whole-struct assignment repro.
//
// Build:
//   bin\mettle.exe --build --emit-obj --linker internal tests\test_struct_copy_repro.mettle -o tests\test_struct_copy_repro.exe
// Run:
//   tests\test_struct_copy_repro.exe
//
// Expected: copied structs preserve every field.
// Observed bug: only the first field is copied; later fields are zero/garbage.
import "std/conv";
import "std/io";

struct TwoI32 {
  a: int32;
  b: int32;
}

struct ThreeI32 {
  a: int32;
  b: int32;
  c: int32;
}

struct TwoF64 {
  a: float64;
  b: float64;
}

struct Mixed {
  a: int32;
  b: float64;
  c: int32;
}

function write_s(s: cstring) {
  if (s != 0) {
    fputs(s, get_stdout());
  }
}

function write_i64(v: int64) {
  var buf: uint8[32];
  int_to_dec((cstring)((int64)(&(buf[0]))), v);
  write_s((cstring)((int64)(&(buf[0]))));
}

function line_i64(label: cstring, v: int64) {
  write_s(label);
  write_s(cstr(" "));
  write_i64(v);
  write_s(cstr("\n"));
}

function scaled(v: float64) -> int64 {
  if (v < 0.0) {
    return 0 - (int64)((0.0 - v) * 1000.0);
  }
  return (int64)(v * 1000.0);
}

function main() -> int32 {
  write_s(cstr("struct copy repro\n"));

  var i0: TwoI32;
  i0.a = 11;
  i0.b = 22;
  var i1: TwoI32 = i0;
  line_i64(cstr("two_i32_a"), (int64)i1.a);
  line_i64(cstr("two_i32_b"), (int64)i1.b);

  var t0: ThreeI32;
  t0.a = 11;
  t0.b = 22;
  t0.c = 33;
  var t1: ThreeI32 = t0;
  line_i64(cstr("three_i32_a"), (int64)t1.a);
  line_i64(cstr("three_i32_b"), (int64)t1.b);
  line_i64(cstr("three_i32_c"), (int64)t1.c);

  var f0: TwoF64;
  f0.a = -3.5;
  f0.b = 22.0;
  var f1: TwoF64 = f0;
  line_i64(cstr("two_f64_a_mm"), scaled(f1.a));
  line_i64(cstr("two_f64_b_mm"), scaled(f1.b));

  var m0: Mixed;
  m0.a = 11;
  m0.b = -3.5;
  m0.c = 22;
  var m1: Mixed = m0;
  line_i64(cstr("mixed_a"), (int64)m1.a);
  line_i64(cstr("mixed_b_mm"), scaled(m1.b));
  line_i64(cstr("mixed_c"), (int64)m1.c);

  return 0;
}
