// Struct + float stress repro.
//
// Build:
//   bin\mettle.exe --build --emit-obj --linker internal tests\test_struct_float_repro.mettle -o tests\test_struct_float_repro.exe
// Run:
//   tests\test_struct_float_repro.exe
//
// This intentionally tries several struct access shapes:
//   - all-float fields
//   - engine-style float64-first layout with trailing int32 fields
//   - mixed int32/float64 fields
//   - local struct copies
//   - pointer mutation
//   - heap-allocated structs
//
// Expected healthy output:
//   scaled reads match the literal values.
//   bounds checks using float comparison should match int-scaled bounds.
import "std/conv";
import "std/io";
import "std/mem";

struct FloatQuad {
  lx: float64;
  lz: float64;
  hx: float64;
  hz: float64;
}

struct EngineStyleProbe {
  lx: float64;
  lz: float64;
  hx: float64;
  hz: float64;
  id: int32;
  flags: int32;
}

struct MixedProbe {
  id: int32;
  lx: float64;
  flags: int32;
  lz: float64;
  marker: int32;
  hx: float64;
  hz: float64;
}

function write_s(s: cstring) {
  if (s != 0) {
    fputs(s, get_stdout());
  }
}

function write_i64(v: int64) {
  var buf: uint8[32];
  int_to_dec((cstring)((int64)(&(buf[0]))), v);
  write_s((cstring)((int64)(&(buf[0]))));
}

function line_i64(label: cstring, v: int64) {
  write_s(label);
  write_s(cstr(" "));
  write_i64(v);
  write_s(cstr("\n"));
}

function line_i32(label: cstring, v: int32) {
  line_i64(label, (int64)v);
}

function scaled(v: float64, scale: float64) -> int64 {
  if (v < 0.0) {
    return 0 - (int64)((0.0 - v) * scale);
  }
  return (int64)(v * scale);
}

function int_scaled_bounds(lx: float64, lz: float64, hx: float64, hz: float64) -> int32 {
  var lxi: int64 = scaled(lx, 1000000.0);
  var lzi: int64 = scaled(lz, 1000000.0);
  var hxi: int64 = scaled(hx, 1000000.0);
  var hzi: int64 = scaled(hz, 1000000.0);
  if (lxi < 0 - hxi) { return 0; }
  if (lxi > hxi) { return 0; }
  if (lzi < 0 - hzi) { return 0; }
  if (lzi > hzi) { return 0; }
  return 1;
}

function float_bounds(lx: float64, lz: float64, hx: float64, hz: float64) -> int32 {
  if (lx < 0.0 - hx) { return 0; }
  if (lx > hx) { return 0; }
  if (lz < 0.0 - hz) { return 0; }
  if (lz > hz) { return 0; }
  return 1;
}

function fill_float_quad(p: FloatQuad*) {
  p->lx = -3348.0;
  p->lz = -9738.0;
  p->hx = 22000.0;
  p->hz = 22000.0;
}

function fill_engine_style(p: EngineStyleProbe*) {
  p->lx = -3348.0;
  p->lz = -9738.0;
  p->hx = 22000.0;
  p->hz = 22000.0;
  p->id = 17;
  p->flags = 99;
}

function fill_mixed(p: MixedProbe*) {
  p->id = 17;
  p->lx = -3348.0;
  p->flags = 99;
  p->lz = -9738.0;
  p->marker = 1234;
  p->hx = 22000.0;
  p->hz = 22000.0;
}

function probe_float_quad(prefix: cstring, p: FloatQuad*) {
  write_s(prefix);
  write_s(cstr("\n"));
  line_i64(cstr("  lx_mm"), scaled(p->lx, 1000.0));
  line_i64(cstr("  lz_mm"), scaled(p->lz, 1000.0));
  line_i64(cstr("  hx_mm"), scaled(p->hx, 1000.0));
  line_i64(cstr("  hz_mm"), scaled(p->hz, 1000.0));
  line_i32(cstr("  float_bounds"), float_bounds(p->lx, p->lz, p->hx, p->hz));
  line_i32(cstr("  int_scaled_bounds"), int_scaled_bounds(p->lx, p->lz, p->hx, p->hz));
}

function probe_engine_style(prefix: cstring, p: EngineStyleProbe*) {
  write_s(prefix);
  write_s(cstr("\n"));
  line_i32(cstr("  id"), p->id);
  line_i32(cstr("  flags"), p->flags);
  line_i64(cstr("  lx_mm"), scaled(p->lx, 1000.0));
  line_i64(cstr("  lz_mm"), scaled(p->lz, 1000.0));
  line_i64(cstr("  hx_mm"), scaled(p->hx, 1000.0));
  line_i64(cstr("  hz_mm"), scaled(p->hz, 1000.0));
  line_i32(cstr("  float_bounds"), float_bounds(p->lx, p->lz, p->hx, p->hz));
  line_i32(cstr("  int_scaled_bounds"), int_scaled_bounds(p->lx, p->lz, p->hx, p->hz));
}

function probe_mixed(prefix: cstring, p: MixedProbe*) {
  write_s(prefix);
  write_s(cstr("\n"));
  line_i32(cstr("  id"), p->id);
  line_i32(cstr("  flags"), p->flags);
  line_i32(cstr("  marker"), p->marker);
  line_i64(cstr("  lx_mm"), scaled(p->lx, 1000.0));
  line_i64(cstr("  lz_mm"), scaled(p->lz, 1000.0));
  line_i64(cstr("  hx_mm"), scaled(p->hx, 1000.0));
  line_i64(cstr("  hz_mm"), scaled(p->hz, 1000.0));
  line_i32(cstr("  float_bounds"), float_bounds(p->lx, p->lz, p->hx, p->hz));
  line_i32(cstr("  int_scaled_bounds"), int_scaled_bounds(p->lx, p->lz, p->hx, p->hz));
}

function main() -> int32 {
  write_s(cstr("struct float repro\n"));

  var fq: FloatQuad;
  fill_float_quad(&fq);
  probe_float_quad(cstr("local FloatQuad"), &fq);
  var fq_copy: FloatQuad = fq;
  probe_float_quad(cstr("copied FloatQuad"), &fq_copy);

  var es: EngineStyleProbe;
  fill_engine_style(&es);
  probe_engine_style(cstr("local EngineStyleProbe"), &es);
  var es_copy: EngineStyleProbe = es;
  probe_engine_style(cstr("copied EngineStyleProbe"), &es_copy);

  var mp: MixedProbe;
  fill_mixed(&mp);
  probe_mixed(cstr("local MixedProbe"), &mp);
  var mp_copy: MixedProbe = mp;
  probe_mixed(cstr("copied MixedProbe"), &mp_copy);

  var raw_es: cstring = calloc((int64)1, (int64)48);
  if (raw_es != 0) {
    var hp: EngineStyleProbe* = (EngineStyleProbe*)raw_es;
    fill_engine_style(hp);
    probe_engine_style(cstr("heap EngineStyleProbe"), hp);
    free(raw_es);
  } else {
    write_s(cstr("heap EngineStyleProbe allocation failed\n"));
  }

  var raw_mp: cstring = calloc((int64)1, (int64)64);
  if (raw_mp != 0) {
    var hm: MixedProbe* = (MixedProbe*)raw_mp;
    fill_mixed(hm);
    probe_mixed(cstr("heap MixedProbe"), hm);
    free(raw_mp);
  } else {
    write_s(cstr("heap MixedProbe allocation failed\n"));
  }

  return 0;
}
