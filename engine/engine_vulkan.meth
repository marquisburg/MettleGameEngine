export extern function vkDestroyFence(device: int64, fence: int64, allocator: int64) = "vkDestroyFence";

export extern function vkCreateShaderModule(device: int64, info: VkShaderModuleCreateInfo*, allocator: int64, out_mod: int64*) -> int32 = "vkCreateShaderModule";
export extern function vkDestroyShaderModule(device: int64, mod: int64, allocator: int64) = "vkDestroyShaderModule";
export extern function vkCreatePipelineLayout(device: int64, info: VkPipelineLayoutCreateInfo*, allocator: int64, out_layout: int64*) -> int32 = "vkCreatePipelineLayout";
export extern function vkDestroyPipelineLayout(device: int64, layout: int64, allocator: int64) = "vkDestroyPipelineLayout";
export extern function vkCreateGraphicsPipelines(device: int64, cache: int64, count: uint32, infos: VkGraphicsPipelineCreateInfo*, allocator: int64, out_pipelines: int64*) -> int32 = "vkCreateGraphicsPipelines";
export extern function vkDestroyPipeline(device: int64, pipeline: int64, allocator: int64) = "vkDestroyPipeline";

export extern function vkWaitForFences(device: int64, count: uint32, fences: int64*, wait_all: uint32, timeout: int64) -> int32 = "vkWaitForFences";
export extern function vkResetFences(device: int64, count: uint32, fences: int64*) -> int32 = "vkResetFences";
export extern function vkAcquireNextImageKHR(device: int64, swapchain: int64, timeout: int64, semaphore: int64, fence: int64, out_index: uint32*) -> int32 = "vkAcquireNextImageKHR";
export extern function vkResetCommandBuffer(cmd: int64, flags: uint32) -> int32 = "vkResetCommandBuffer";
export extern function vkBeginCommandBuffer(cmd: int64, info: VkCommandBufferBeginInfo*) -> int32 = "vkBeginCommandBuffer";
export extern function vkEndCommandBuffer(cmd: int64) -> int32 = "vkEndCommandBuffer";
export extern function vkCmdBeginRenderPass(cmd: int64, info: VkRenderPassBeginInfo*, contents: uint32) = "vkCmdBeginRenderPass";
export extern function vkCmdEndRenderPass(cmd: int64) = "vkCmdEndRenderPass";
export extern function vkCmdBindPipeline(cmd: int64, bind_point: uint32, pipeline: int64) = "vkCmdBindPipeline";
export extern function vkCmdSetViewport(cmd: int64, first: uint32, count: uint32, viewports: VkViewport*) = "vkCmdSetViewport";
export extern function vkCmdSetScissor(cmd: int64, first: uint32, count: uint32, scissors: VkRect2D*) = "vkCmdSetScissor";
export extern function vkCmdDraw(cmd: int64, vertex_count: uint32, instance_count: uint32, first_vertex: uint32, first_instance: uint32) = "vkCmdDraw";
export extern function vkQueueSubmit(queue: int64, count: uint32, submits: VkSubmitInfo*, fence: int64) -> int32 = "vkQueueSubmit";
export extern function vkQueuePresentKHR(queue: int64, info: VkPresentInfoKHR*) -> int32 = "vkQueuePresentKHR";
export extern function vkQueueWaitIdle(queue: int64) -> int32 = "vkQueueWaitIdle";

export extern function vkCreateBuffer(device: int64, info: VkBufferCreateInfo*, allocator: int64, out_buf: int64*) -> int32 = "vkCreateBuffer";
export extern function vkDestroyBuffer(device: int64, buf: int64, allocator: int64) = "vkDestroyBuffer";
export extern function vkGetBufferMemoryRequirements(device: int64, buf: int64, out_req: VkMemoryRequirements*) = "vkGetBufferMemoryRequirements";
export extern function vkGetImageMemoryRequirements(device: int64, img: int64, out_req: VkMemoryRequirements*) = "vkGetImageMemoryRequirements";
export extern function vkGetPhysicalDeviceMemoryProperties(phys: int64, out_props: VkPhysicalDeviceMemoryProperties*) = "vkGetPhysicalDeviceMemoryProperties";
export extern function vkAllocateMemory(device: int64, info: VkMemoryAllocateInfo*, allocator: int64, out_mem: int64*) -> int32 = "vkAllocateMemory";
export extern function vkFreeMemory(device: int64, mem: int64, allocator: int64) = "vkFreeMemory";
export extern function vkBindBufferMemory(device: int64, buf: int64, mem: int64, offset: int64) -> int32 = "vkBindBufferMemory";
export extern function vkBindImageMemory(device: int64, img: int64, mem: int64, offset: int64) -> int32 = "vkBindImageMemory";
