// Vulkan backend for the editor viewport. Windows + internal linker.
// Build the host with:  --link-arg -lvulkan-1
//
// HARD RULE: declare every struct field in Vulkan spec order with the correct
// type. Methlang lays fields out in declaration order and AUTO-ALIGNS them to
// the target C ABI (verified empirically: a uint32 followed by an int64 places
// the int64 at offset 8, exactly like C). So do NOT add manual padding fields
// here -- doing so double-pads and shifts every pointer, which the driver
// reports as VK_ERROR_INITIALIZATION_FAILED (a wrong offset never errors at
// the language level, it just corrupts the call).
//
// No SPIR-V toolchain exists on the build machine, so the vertex/fragment
// shaders are hand-assembled SPIR-V word arrays (see engine_vk_shaders).
import "engine_vk_shaders";
import "game_gdi_win32";
import "std/io";
import "std/mem";

// Forward declaration: the flattened module can emit exported functions before
// later-defined helpers, so calls to vk_say from the exported create functions
// resolve only with this prototype (same pattern as game_gdi_win32).
function vk_say(msg: string);

// ---- Structure type enum values (subset we use) -----------------------------
function VK_ST_APPLICATION_INFO() -> uint32 { return (uint32)0; }
function VK_ST_INSTANCE_CREATE_INFO() -> uint32 { return (uint32)1; }
function VK_ST_DEVICE_QUEUE_CREATE_INFO() -> uint32 { return (uint32)2; }
function VK_ST_DEVICE_CREATE_INFO() -> uint32 { return (uint32)3; }
function VK_ST_SUBMIT_INFO() -> uint32 { return (uint32)4; }
function VK_ST_FENCE_CREATE_INFO() -> uint32 { return (uint32)8; }
function VK_ST_SEMAPHORE_CREATE_INFO() -> uint32 { return (uint32)9; }
function VK_ST_IMAGE_VIEW_CREATE_INFO() -> uint32 { return (uint32)15; }
function VK_ST_SHADER_MODULE_CREATE_INFO() -> uint32 { return (uint32)16; }
function VK_ST_PIPELINE_SHADER_STAGE_CREATE_INFO() -> uint32 { return (uint32)18; }
function VK_ST_PIPELINE_VERTEX_INPUT_STATE_CREATE_INFO() -> uint32 { return (uint32)19; }
function VK_ST_PIPELINE_INPUT_ASSEMBLY_STATE_CREATE_INFO() -> uint32 { return (uint32)20; }
function VK_ST_PIPELINE_VIEWPORT_STATE_CREATE_INFO() -> uint32 { return (uint32)22; }
function VK_ST_PIPELINE_RASTERIZATION_STATE_CREATE_INFO() -> uint32 { return (uint32)23; }
function VK_ST_PIPELINE_MULTISAMPLE_STATE_CREATE_INFO() -> uint32 { return (uint32)24; }
function VK_ST_PIPELINE_COLOR_BLEND_STATE_CREATE_INFO() -> uint32 { return (uint32)26; }
function VK_ST_GRAPHICS_PIPELINE_CREATE_INFO() -> uint32 { return (uint32)28; }
function VK_ST_PIPELINE_LAYOUT_CREATE_INFO() -> uint32 { return (uint32)30; }
function VK_ST_FRAMEBUFFER_CREATE_INFO() -> uint32 { return (uint32)37; }
function VK_ST_RENDER_PASS_CREATE_INFO() -> uint32 { return (uint32)38; }
function VK_ST_COMMAND_POOL_CREATE_INFO() -> uint32 { return (uint32)39; }
function VK_ST_COMMAND_BUFFER_ALLOCATE_INFO() -> uint32 { return (uint32)40; }
function VK_ST_COMMAND_BUFFER_BEGIN_INFO() -> uint32 { return (uint32)42; }
function VK_ST_RENDER_PASS_BEGIN_INFO() -> uint32 { return (uint32)43; }
function VK_ST_WIN32_SURFACE_CREATE_INFO_KHR() -> uint32 { return (uint32)1000009000; }
function VK_ST_SWAPCHAIN_CREATE_INFO_KHR() -> uint32 { return (uint32)1000001000; }
function VK_ST_PRESENT_INFO_KHR() -> uint32 { return (uint32)1000001001; }

function VK_API_VERSION_1_0() -> uint32 { return (uint32)4194304; }
function VK_FORMAT_B8G8R8A8_UNORM() -> uint32 { return (uint32)44; }
function VK_SUCCESS() -> int32 { return 0; }

// ---- Core structs (C ABI) ---------------------------------------------------
export struct VkApplicationInfo {
  s_type: uint32;
  p_next: int64;
  p_application_name: int64;
  application_version: uint32;
  p_engine_name: int64;
  engine_version: uint32;
  api_version: uint32;
}

export struct VkInstanceCreateInfo {
  s_type: uint32;
  p_next: int64;
  flags: uint32;
  p_application_info: int64;
  enabled_layer_count: uint32;
  pp_enabled_layer_names: int64;
  enabled_extension_count: uint32;
  pp_enabled_extension_names: int64;
}

// deviceName starts at offset 20 (5 * uint32, char array is 1-byte aligned).
export struct VkPhysicalDeviceProperties {
  api_version: uint32;
  driver_version: uint32;
  vendor_id: uint32;
  device_id: uint32;
  device_type: uint32;
  device_name: uint8[256];
  pipeline_cache_uuid: uint8[16];
  limits_blob: uint8[504];
  sparse_blob: uint8[32];
}

// VkQueueFamilyProperties: queueFlags(4) queueCount(4) timestampValidBits(4)
// minImageTransferGranularity{w,h,d}(12) = 24 bytes, no internal padding.
export struct VkQueueFamilyProperties {
  queue_flags: uint32;
  queue_count: uint32;
  timestamp_valid_bits: uint32;
  min_transfer_w: uint32;
  min_transfer_h: uint32;
  min_transfer_d: uint32;
}

export struct VkDeviceQueueCreateInfo {
  s_type: uint32;
  p_next: int64;
  flags: uint32;
  queue_family_index: uint32;
  queue_count: uint32;
  p_queue_priorities: int64;
}

export struct VkDeviceCreateInfo {
  s_type: uint32;
  p_next: int64;
  flags: uint32;
  queue_create_info_count: uint32;
  p_queue_create_infos: int64;
  enabled_layer_count: uint32;
  pp_enabled_layer_names: int64;
  enabled_extension_count: uint32;
  pp_enabled_extension_names: int64;
  p_enabled_features: int64;
}

// VkWin32SurfaceCreateInfoKHR: sType, pNext, flags, hinstance, hwnd.
export struct VkWin32SurfaceCreateInfoKHR {
  s_type: uint32;
  p_next: int64;
  flags: uint32;
  hinstance: int64;
  hwnd: int64;
}

// VkSurfaceCapabilitiesKHR (C ABI). minImageCount.. are uint32; the VkExtent2D
// fields are two uint32 each.
export struct VkSurfaceCapabilitiesKHR {
  min_image_count: uint32;
  max_image_count: uint32;
  cur_extent_w: uint32;
  cur_extent_h: uint32;
  min_extent_w: uint32;
  min_extent_h: uint32;
  max_extent_w: uint32;
  max_extent_h: uint32;
  max_image_array_layers: uint32;
  supported_transforms: uint32;
  current_transform: uint32;
  supported_composite_alpha: uint32;
  supported_usage_flags: uint32;
}

// VkSurfaceFormatKHR: format(uint32) colorSpace(uint32).
export struct VkSurfaceFormatKHR {
  format: uint32;
  color_space: uint32;
}

export struct VkSwapchainCreateInfoKHR {
  s_type: uint32;
  p_next: int64;
  flags: uint32;
  surface: int64;
  min_image_count: uint32;
  image_format: uint32;
  image_color_space: uint32;
  image_extent_w: uint32;
  image_extent_h: uint32;
  image_array_layers: uint32;
  image_usage: uint32;
  image_sharing_mode: uint32;
  queue_family_index_count: uint32;
  p_queue_family_indices: int64;
  pre_transform: uint32;
  composite_alpha: uint32;
  present_mode: uint32;
  clipped: uint32;
  old_swapchain: int64;
}

// VkImageViewCreateInfo. components{r,g,b,a} are 4 uint32; subresourceRange is
// aspectMask, baseMipLevel, levelCount, baseArrayLayer, layerCount (5 uint32).
export struct VkImageViewCreateInfo {
  s_type: uint32;
  p_next: int64;
  flags: uint32;
  image: int64;
  view_type: uint32;
  format: uint32;
  comp_r: uint32;
  comp_g: uint32;
  comp_b: uint32;
  comp_a: uint32;
  aspect_mask: uint32;
  base_mip: uint32;
  level_count: uint32;
  base_array: uint32;
  layer_count: uint32;
}

// VkAttachmentDescription (plain struct, no sType): flags, format, samples,
// loadOp, storeOp, stencilLoadOp, stencilStoreOp, initialLayout, finalLayout.
export struct VkAttachmentDescription {
  flags: uint32;
  format: uint32;
  samples: uint32;
  load_op: uint32;
  store_op: uint32;
  stencil_load_op: uint32;
  stencil_store_op: uint32;
  initial_layout: uint32;
  final_layout: uint32;
}

export struct VkAttachmentReference {
  attachment: uint32;
  layout: uint32;
}

// VkSubpassDescription: flags, pipelineBindPoint, inputAttachmentCount,
// pInputAttachments, colorAttachmentCount, pColorAttachments, pResolve,
// pDepthStencil, preserveCount, pPreserve.
export struct VkSubpassDescription {
  flags: uint32;
  pipeline_bind_point: uint32;
  input_attachment_count: uint32;
  p_input_attachments: int64;
  color_attachment_count: uint32;
  p_color_attachments: int64;
  p_resolve_attachments: int64;
  p_depth_stencil_attachment: int64;
  preserve_attachment_count: uint32;
  p_preserve_attachments: int64;
}

// VkSubpassDependency: srcSubpass, dstSubpass, srcStageMask, dstStageMask,
// srcAccessMask, dstAccessMask, dependencyFlags (7 uint32).
export struct VkSubpassDependency {
  src_subpass: uint32;
  dst_subpass: uint32;
  src_stage_mask: uint32;
  dst_stage_mask: uint32;
  src_access_mask: uint32;
  dst_access_mask: uint32;
  dependency_flags: uint32;
}

export struct VkRenderPassCreateInfo {
  s_type: uint32;
  p_next: int64;
  flags: uint32;
  attachment_count: uint32;
  p_attachments: int64;
  subpass_count: uint32;
  p_subpasses: int64;
  dependency_count: uint32;
  p_dependencies: int64;
}

export struct VkFramebufferCreateInfo {
  s_type: uint32;
  p_next: int64;
  flags: uint32;
  render_pass: int64;
  attachment_count: uint32;
  p_attachments: int64;
  width: uint32;
  height: uint32;
  layers: uint32;
}

export struct VkCommandPoolCreateInfo {
  s_type: uint32;
  p_next: int64;
  flags: uint32;
  queue_family_index: uint32;
}

export struct VkCommandBufferAllocateInfo {
  s_type: uint32;
  p_next: int64;
  command_pool: int64;
  level: uint32;
  command_buffer_count: uint32;
}

export struct VkSemaphoreCreateInfo {
  s_type: uint32;
  p_next: int64;
  flags: uint32;
}

export struct VkFenceCreateInfo {
  s_type: uint32;
  p_next: int64;
  flags: uint32;
}

export struct VkShaderModuleCreateInfo {
  s_type: uint32;
  p_next: int64;
  flags: uint32;
  code_size: int64;
  p_code: int64;
}

// stage, module, pName, pSpecializationInfo. stage(uint32) then 4 pad then the
// 8-byte module handle (auto-aligned).
export struct VkPipelineShaderStageCreateInfo {
  s_type: uint32;
  p_next: int64;
  flags: uint32;
  stage: uint32;
  module_handle: int64;
  p_name: int64;
  p_specialization_info: int64;
}

export struct VkPipelineVertexInputStateCreateInfo {
  s_type: uint32;
  p_next: int64;
  flags: uint32;
  vertex_binding_description_count: uint32;
  p_vertex_binding_descriptions: int64;
  vertex_attribute_description_count: uint32;
  p_vertex_attribute_descriptions: int64;
}

export struct VkPipelineInputAssemblyStateCreateInfo {
  s_type: uint32;
  p_next: int64;
  flags: uint32;
  topology: uint32;
  primitive_restart_enable: uint32;
}

// VkViewport is all float32: x,y,width,height,minDepth,maxDepth.
export struct VkViewport {
  x: float32;
  y: float32;
  width: float32;
  height: float32;
  min_depth: float32;
  max_depth: float32;
}

// VkRect2D = offset{int32 x,y} + extent{uint32 w,h}.
export struct VkRect2D {
  offset_x: int32;
  offset_y: int32;
  extent_w: uint32;
  extent_h: uint32;
}

export struct VkPipelineViewportStateCreateInfo {
  s_type: uint32;
  p_next: int64;
  flags: uint32;
  viewport_count: uint32;
  p_viewports: int64;
  scissor_count: uint32;
  p_scissors: int64;
}

// depthClampEnable, rasterizerDiscardEnable, polygonMode, cullMode, frontFace,
// depthBiasEnable, depthBiasConstantFactor, depthBiasClamp, depthBiasSlope,
// lineWidth. The trailing 4 are float32.
export struct VkPipelineRasterizationStateCreateInfo {
  s_type: uint32;
  p_next: int64;
  flags: uint32;
  depth_clamp_enable: uint32;
  rasterizer_discard_enable: uint32;
  polygon_mode: uint32;
  cull_mode: uint32;
  front_face: uint32;
  depth_bias_enable: uint32;
  depth_bias_constant_factor: float32;
  depth_bias_clamp: float32;
  depth_bias_slope_factor: float32;
  line_width: float32;
}

export struct VkPipelineMultisampleStateCreateInfo {
  s_type: uint32;
  p_next: int64;
  flags: uint32;
  rasterization_samples: uint32;
  sample_shading_enable: uint32;
  min_sample_shading: float32;
  p_sample_mask: int64;
  alpha_to_coverage_enable: uint32;
  alpha_to_one_enable: uint32;
}

// blendEnable, srcColor, dstColor, colorOp, srcAlpha, dstAlpha, alphaOp,
// colorWriteMask (8 uint32, no padding).
export struct VkPipelineColorBlendAttachmentState {
  blend_enable: uint32;
  src_color_blend_factor: uint32;
  dst_color_blend_factor: uint32;
  color_blend_op: uint32;
  src_alpha_blend_factor: uint32;
  dst_alpha_blend_factor: uint32;
  alpha_blend_op: uint32;
  color_write_mask: uint32;
}

export struct VkPipelineColorBlendStateCreateInfo {
  s_type: uint32;
  p_next: int64;
  flags: uint32;
  logic_op_enable: uint32;
  logic_op: uint32;
  attachment_count: uint32;
  p_attachments: int64;
  blend_constant0: float32;
  blend_constant1: float32;
  blend_constant2: float32;
  blend_constant3: float32;
}

export struct VkPipelineDynamicStateCreateInfo {
  s_type: uint32;
  p_next: int64;
  flags: uint32;
  dynamic_state_count: uint32;
  p_dynamic_states: int64;
}

export struct VkPipelineLayoutCreateInfo {
  s_type: uint32;
  p_next: int64;
  flags: uint32;
  set_layout_count: uint32;
  p_set_layouts: int64;
  push_constant_range_count: uint32;
  p_push_constant_ranges: int64;
}

export struct VkGraphicsPipelineCreateInfo {
  s_type: uint32;
  p_next: int64;
  flags: uint32;
  stage_count: uint32;
  p_stages: int64;
  p_vertex_input_state: int64;
  p_input_assembly_state: int64;
  p_tessellation_state: int64;
  p_viewport_state: int64;
  p_rasterization_state: int64;
  p_multisample_state: int64;
  p_depth_stencil_state: int64;
  p_color_blend_state: int64;
  p_dynamic_state: int64;
  layout: int64;
  render_pass: int64;
  subpass: uint32;
  base_pipeline_handle: int64;
  base_pipeline_index: int32;
}

export struct VkCommandBufferBeginInfo {
  s_type: uint32;
  p_next: int64;
  flags: uint32;
  p_inheritance_info: int64;
}

// VkClearValue is a union; for a color clear it is 4 float32 (RGBA).
export struct VkClearValue {
  r: float32;
  g: float32;
  b: float32;
  a: float32;
}

export struct VkRenderPassBeginInfo {
  s_type: uint32;
  p_next: int64;
  render_pass: int64;
  framebuffer: int64;
  render_area_offset_x: int32;
  render_area_offset_y: int32;
  render_area_extent_w: uint32;
  render_area_extent_h: uint32;
  clear_value_count: uint32;
  p_clear_values: int64;
}

// waitSemaphoreCount, pWaitSemaphores, pWaitDstStageMask, commandBufferCount,
// pCommandBuffers, signalSemaphoreCount, pSignalSemaphores.
export struct VkSubmitInfo {
  s_type: uint32;
  p_next: int64;
  wait_semaphore_count: uint32;
  p_wait_semaphores: int64;
  p_wait_dst_stage_mask: int64;
  command_buffer_count: uint32;
  p_command_buffers: int64;
  signal_semaphore_count: uint32;
  p_signal_semaphores: int64;
}

export struct VkPresentInfoKHR {
  s_type: uint32;
  p_next: int64;
  wait_semaphore_count: uint32;
  p_wait_semaphores: int64;
  swapchain_count: uint32;
  p_swapchains: int64;
  p_image_indices: int64;
  p_results: int64;
}

// binding, stride, inputRate (3 uint32, no padding).
export struct VkVertexInputBindingDescription {
  binding: uint32;
  stride: uint32;
  input_rate: uint32;
}

// location, binding, format, offset (4 uint32).
export struct VkVertexInputAttributeDescription {
  location: uint32;
  binding: uint32;
  format: uint32;
  offset: uint32;
}

// stageFlags, offset, size (3 uint32).
export struct VkPushConstantRange {
  stage_flags: uint32;
  offset: uint32;
  size: uint32;
}

export struct VkBufferCreateInfo {
  s_type: uint32;
  p_next: int64;
  flags: uint32;
  size: int64;
  usage: uint32;
  sharing_mode: uint32;
  queue_family_index_count: uint32;
  p_queue_family_indices: int64;
}

// VkMemoryRequirements: size(8) alignment(8) memoryTypeBits(4).
export struct VkMemoryRequirements {
  size: int64;
  alignment: int64;
  memory_type_bits: uint32;
}

export struct VkMemoryAllocateInfo {
  s_type: uint32;
  p_next: int64;
  allocation_size: int64;
  memory_type_index: uint32;
}

// VkMemoryType: propertyFlags(4) heapIndex(4). VkMemoryHeap: size(8) flags(4).
// VkPhysicalDeviceMemoryProperties: memoryTypeCount(4), memoryTypes[32]
// (8 bytes each = 256), memoryHeapCount(4), memoryHeaps[16] (16 bytes each =
// 256). We over-size and read by manual offset to avoid struct-array nuance.
export struct VkPhysicalDeviceMemoryProperties {
  memory_type_count: uint32;
  mem_types_blob: uint8[256];
  memory_heap_count: uint32;
  mem_heaps_blob: uint8[256];
}

export struct VkImageCreateInfo {
  s_type: uint32;
  p_next: int64;
  flags: uint32;
  image_type: uint32;
  format: uint32;
  extent_w: uint32;
  extent_h: uint32;
  extent_d: uint32;
  mip_levels: uint32;
  array_layers: uint32;
  samples: uint32;
  tiling: uint32;
  usage: uint32;
  sharing_mode: uint32;
  queue_family_index_count: uint32;
  p_queue_family_indices: int64;
  initial_layout: uint32;
}

export struct VkPipelineDepthStencilStateCreateInfo {
  s_type: uint32;
  p_next: int64;
  flags: uint32;
  depth_test_enable: uint32;
  depth_write_enable: uint32;
  depth_compare_op: uint32;
  depth_bounds_test_enable: uint32;
  stencil_test_enable: uint32;
  front_fail_op: uint32;
  front_pass_op: uint32;
  front_depth_fail_op: uint32;
  front_compare_op: uint32;
  front_compare_mask: uint32;
  front_write_mask: uint32;
  front_reference: uint32;
  back_fail_op: uint32;
  back_pass_op: uint32;
  back_depth_fail_op: uint32;
  back_compare_op: uint32;
  back_compare_mask: uint32;
  back_write_mask: uint32;
  back_reference: uint32;
  min_depth_bounds: float32;
  max_depth_bounds: float32;
}

// ---- Extern entry points ----------------------------------------------------
export extern function vkCreateInstance(create_info: VkInstanceCreateInfo*, allocator: int64, out_instance: int64*) -> int32 = "vkCreateInstance";
export extern function vkDestroyInstance(instance: int64, allocator: int64) = "vkDestroyInstance";
export extern function vkEnumeratePhysicalDevices(instance: int64, count: uint32*, devices: int64*) -> int32 = "vkEnumeratePhysicalDevices";
export extern function vkGetPhysicalDeviceProperties(phys: int64, props: VkPhysicalDeviceProperties*) = "vkGetPhysicalDeviceProperties";
export extern function vkGetPhysicalDeviceQueueFamilyProperties(phys: int64, count: uint32*, props: VkQueueFamilyProperties*) = "vkGetPhysicalDeviceQueueFamilyProperties";
export extern function vkCreateDevice(phys: int64, create_info: VkDeviceCreateInfo*, allocator: int64, out_device: int64*) -> int32 = "vkCreateDevice";
export extern function vkDestroyDevice(device: int64, allocator: int64) = "vkDestroyDevice";
export extern function vkGetDeviceQueue(device: int64, family: uint32, index: uint32, out_queue: int64*) = "vkGetDeviceQueue";
export extern function vkDeviceWaitIdle(device: int64) -> int32 = "vkDeviceWaitIdle";

export extern function vkCreateWin32SurfaceKHR(instance: int64, info: VkWin32SurfaceCreateInfoKHR*, allocator: int64, out_surface: int64*) -> int32 = "vkCreateWin32SurfaceKHR";
export extern function vkDestroySurfaceKHR(instance: int64, surface: int64, allocator: int64) = "vkDestroySurfaceKHR";
export extern function vkGetPhysicalDeviceSurfaceSupportKHR(phys: int64, family: uint32, surface: int64, out_supported: uint32*) -> int32 = "vkGetPhysicalDeviceSurfaceSupportKHR";
export extern function vkGetPhysicalDeviceSurfaceCapabilitiesKHR(phys: int64, surface: int64, out_caps: VkSurfaceCapabilitiesKHR*) -> int32 = "vkGetPhysicalDeviceSurfaceCapabilitiesKHR";
export extern function vkGetPhysicalDeviceSurfaceFormatsKHR(phys: int64, surface: int64, count: uint32*, formats: VkSurfaceFormatKHR*) -> int32 = "vkGetPhysicalDeviceSurfaceFormatsKHR";
export extern function vkGetPhysicalDeviceSurfacePresentModesKHR(phys: int64, surface: int64, count: uint32*, modes: uint32*) -> int32 = "vkGetPhysicalDeviceSurfacePresentModesKHR";
export extern function vkCreateSwapchainKHR(device: int64, info: VkSwapchainCreateInfoKHR*, allocator: int64, out_swapchain: int64*) -> int32 = "vkCreateSwapchainKHR";
export extern function vkDestroySwapchainKHR(device: int64, swapchain: int64, allocator: int64) = "vkDestroySwapchainKHR";
export extern function vkGetSwapchainImagesKHR(device: int64, swapchain: int64, count: uint32*, images: int64*) -> int32 = "vkGetSwapchainImagesKHR";
export extern function vkCreateImageView(device: int64, info: VkImageViewCreateInfo*, allocator: int64, out_view: int64*) -> int32 = "vkCreateImageView";
export extern function vkDestroyImageView(device: int64, view: int64, allocator: int64) = "vkDestroyImageView";

export extern function vkCreateRenderPass(device: int64, info: VkRenderPassCreateInfo*, allocator: int64, out_rp: int64*) -> int32 = "vkCreateRenderPass";
export extern function vkDestroyRenderPass(device: int64, rp: int64, allocator: int64) = "vkDestroyRenderPass";
export extern function vkCreateFramebuffer(device: int64, info: VkFramebufferCreateInfo*, allocator: int64, out_fb: int64*) -> int32 = "vkCreateFramebuffer";
export extern function vkDestroyFramebuffer(device: int64, fb: int64, allocator: int64) = "vkDestroyFramebuffer";
export extern function vkCreateCommandPool(device: int64, info: VkCommandPoolCreateInfo*, allocator: int64, out_pool: int64*) -> int32 = "vkCreateCommandPool";
export extern function vkDestroyCommandPool(device: int64, pool: int64, allocator: int64) = "vkDestroyCommandPool";
export extern function vkAllocateCommandBuffers(device: int64, info: VkCommandBufferAllocateInfo*, out_buffers: int64*) -> int32 = "vkAllocateCommandBuffers";
export extern function vkCreateSemaphore(device: int64, info: VkSemaphoreCreateInfo*, allocator: int64, out_sem: int64*) -> int32 = "vkCreateSemaphore";
export extern function vkDestroySemaphore(device: int64, sem: int64, allocator: int64) = "vkDestroySemaphore";
