// WS_CHILD (0x40000000) | WS_VISIBLE (0x10000000) | WS_CLIPSIBLINGS
// (0x04000000). A child window for the Vulkan swapchain: clipped to the
// viewport rect, no border, parented to the editor window.
export function WIN32_WS_CHILD_VISIBLE() -> uint32 {
  return (uint32)1342177280;
}

export function GDI_BKMODE_TRANSPARENT() -> int32 {
  return 1;
}

export function COLORREF_WHITE() -> uint32 {
  return (uint32)16777215;
}

export function COLORREF_DIM_TEXT() -> uint32 {
  return (uint32)12632256;
}

// GDI COLORREF is 0x00BBGGRR (high byte zero). This differs from the
// framebuffer pixel layout produced by swizzle_bgra8 (0xAARRGGBB), so text
// color must be built with this, not swizzle_bgra8 — passing a swizzled pixel
// to SetTextColor sets the high byte and GDI renders it as black.
export function colorref_rgb(r: uint8, g: uint8, b: uint8) -> uint32 {
  var ur: uint32 = ((uint32)r) & (uint32)255;
  var ug: uint32 = ((uint32)g) & (uint32)255;
  var ub: uint32 = ((uint32)b) & (uint32)255;
  return ub * (uint32)65536 + ug * (uint32)256 + ur;
}

