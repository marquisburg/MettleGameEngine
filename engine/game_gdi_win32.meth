  pt_y: int32;
  _pad_tail: uint32;
}

export struct Win32Point {
  x: int32;
  y: int32;
}

// PAINTSTRUCT (x64): hdc, fErase, rcPaint(4 LONG), fRestore, fIncUpdate, 32-byte
// rgbReserved. We never read past hdc; padding kept so BeginPaint can fill it.
export struct Win32PaintStruct {
  hdc: int64;
  f_erase: int32;
  rc_left: int32;
  rc_top: int32;
  rc_right: int32;
  rc_bottom: int32;
  f_restore: int32;
  f_inc_update: int32;
  rgb_reserved0: int64;
  rgb_reserved1: int64;
  rgb_reserved2: int64;
  rgb_reserved3: int64;
}

export struct Win32WndClassExA {
  cb_size: uint32;
  style: uint32;
  lpfn_wnd_proc: int64;
  cb_cls_extra: int32;
  cb_wnd_extra: int32;
  instance: int64;
  icon: int64;
  cursor: int64;
  brush_bg: int64;
  menu_name: int64;
