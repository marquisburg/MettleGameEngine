// Windows-only MIN game loop: Win32 window + PeekMessage dispatch + StretchDIBits
// from a caller-owned RGBA (BGRA packed) framebuffer. Targets --build --emit-obj
// --linker internal (kernel32/user32/gdi32 already resolved by Methlang linker).
//
import "std/mem";

function gcw_cstr_lit(s: string) -> cstring {
  return s.chars;
}

export struct GameWin32 {
  hwnd: int64;
  hinstance: int64;
  pixels: uint32*;
  qpc_frequency: int64;
  prev_qpc: int64;
  key_bits0: int64;
  key_bits1: int64;
  key_bits2: int64;
  key_bits3: int64;
  mem_dc: int64;
  dib: int64;
  old_dib: int64;
  width: int32;
  height: int32;
  stride_px: int32;
  running: int32;
  mouse_captured: int32;
  capture_saved_x: int32;
  capture_saved_y: int32;
  capture_anchor_x: int32;
  capture_anchor_y: int32;
  pending_resize_w: int32;
  pending_resize_h: int32;
  resize_dirty: int32;
  child_hwnd: int64;
  child_x: int32;
  child_y: int32;
  child_w: int32;
  child_h: int32;
}

var GAME_WIN32_ACTIVE: GameWin32* = 0;
var GAME_WIN32_WHEEL_ACCUM: int32 = 0;

export struct Win32Rect {
  left: int32;
  top: int32;
  right: int32;
  bottom: int32;
}

